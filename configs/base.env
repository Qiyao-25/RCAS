# 基础运行配置。真实系统环境变量会覆盖本文件同名键。

# 预算
BUDGET_DAILY_LIMIT=50
BUDGET_MAX_STEPS=20
BUDGET_GENERATOR_COST=1
BUDGET_CRITIC_COST=1

# UCB 方向选择
UCB_C=1.5
UCB_C_DECAY=0.95
UCB_MIN_C=0.3

# 评估阈值
EVAL_IV_THRESHOLD=0.005
EVAL_KS_THRESHOLD=0.01
EVAL_MISSING_RATE_THRESHOLD=0.7
EVAL_PSI_THRESHOLD=0.25
EVAL_N_BINS=10

# Generator
GENERATOR_K_FEATURES_PER_STEP=3
GENERATOR_TEMPERATURE=0.7
GENERATOR_MAX_TOKENS=2048
GENERATOR_MODEL=deepseek-v4-pro

# Critic
CRITIC_TEMPERATURE=0.3
CRITIC_MAX_TOKENS=1024
CRITIC_MODEL=deepseek-v4-pro
CRITIC_FAILURE_THRESHOLD=0.2

# LLM: 默认调用 OpenAI 兼容接口；如需离线调试可临时设为 mock
LLM_MODE=api
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_ALLOW_MOCK_FALLBACK=false

# 数据源：默认使用真实 Home Credit 数据集
DATA_SOURCE=home_credit
HOME_CREDIT_DIR=

# 挖掘方向，逗号分隔。少量方向适合 POC；生产建议拆成“领域 x 模板族”两层。
DIRECTIONS=user_device_risk,transaction_pattern,geolocation_anomaly,account_behavior,network_relation

# 分层探索策略空间
TEMPLATE_FAMILIES=time_window_agg,ratio_share,volatility,cross_feature,anomaly_distance,stability_shift
TRANSFORM_STRATEGIES=raw,log,woe_bin,quantile_bin,missing_indicator,interaction

# 跨运行优秀因子知识库
FEATURE_BANK_PATH=knowledge/feature_bank.json

# 合规
COMPLIANCE_REQUIRED_TAGS=PII_FREE,EXPLAINABLE
COMPLIANCE_FORBIDDEN_FIELDS=id_number,phone,name,email_raw

# 日志
LOG_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
LOG_FILE=logs/agent.log

# 每次运行会落到 RUN_BASE_DIR/<run_id>/ 下
RUN_BASE_DIR=runs

# 可追溯记录
TRACE_ENABLED=true
